      "firebaseStorageBucket": "sidhealthcareapp.firebasestorage.app",
      "firebaseMessagingSenderId": "506606835618",
      "firebaseAppId": "1:506606835618:web:d35690e459e8e7fbc6c4fb",
      "firebaseDatabaseUrl": "https://sidhealthcareapp-default-rtdb.firebaseio.com",
      "firebaseMeasurementId": "G-K8RFJ5LZ5Y",
      "router": {},
      "eas": {
        "projectId": "636f9969-2a06-4b83-b263-54162feb0f46"
      }
    }
  }
}
